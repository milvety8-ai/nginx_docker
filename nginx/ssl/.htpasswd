# Вариант 1: Если установлен apache2-utils
htpasswd -c nginx/ssl/.htpasswd student

# Вариант 2: Через Python (без зависимостей)
python3 -c "
import crypt, getpass
user = 'student'
passwd = 'password123'
h = crypt.crypt(passwd, crypt.mksalt(crypt.METHOD_SHA512))
print(f'{user}:{h}')
" > nginx/ssl/.htpasswd

# Вариант 3: Через Docker (не нужно ничего устанавливать)
docker run --rm httpd:2.4-alpine htpasswd -nb student password123 \
    > nginx/ssl/.htpasswd
